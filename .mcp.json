{
  "mcpServers": {
    "tgctl-claude-channel": {
      "command": "tgctl-claude-channel",
      "env": {
        "TGCTL_TOKEN": "${TGCTL_TOKEN}",
        "TGCTL_CHANNEL_ALLOW": "${TGCTL_CHANNEL_ALLOW}",
        "TGCTL_CHANNEL_PORT": "${TGCTL_CHANNEL_PORT}",
        "TGCTL_CHANNEL_SECRET": "${TGCTL_CHANNEL_SECRET}",
        "TGCTL_CHANNEL_SET_URL": "${TGCTL_CHANNEL_SET_URL}",
        "TGCTL_CHANNEL_INJECT_PORT": "${TGCTL_CHANNEL_INJECT_PORT}",
        "TGCTL_CHANNEL_INJECT_SECRET": "${TGCTL_CHANNEL_INJECT_SECRET}",
        "TGCTL_CHANNEL_INJECT_BIND": "${TGCTL_CHANNEL_INJECT_BIND}",
        "TGCTL_CHANNEL_COMMAND_HANDLER": "${TGCTL_CHANNEL_COMMAND_HANDLER}",
        "TGCTL_CHANNEL_TMUX_TARGET": "${TGCTL_CHANNEL_TMUX_TARGET}",
        "TGCTL_BIN": "${TGCTL_BIN}"
      }
    }
  }
}
