# /etc/tgctl-claude/channel.env   — chmod 600, root or service-user owned.
# Loaded by the systemd unit; inherited by the channel MCP subprocess.

# Bot token (from @BotFather). ROTATE the one shared in chat before using.
TGCTL_TOKEN=123456:REPLACE_ME

# Allowlisted Telegram sender user_ids (comma-separated). The security gate.
# Juan's id is 1478765505.
TGCTL_CHANNEL_ALLOW=1478765505

# Local port the embedded `tgctl webhook listen` binds (behind the tunnel).
TGCTL_CHANNEL_PORT=8090

# Secret echoed by Telegram in X-Telegram-Bot-Api-Secret-Token. Generate with
# `openssl rand -hex 16`. Rejects any inbound POST that lacks it.
TGCTL_CHANNEL_SECRET=REPLACE_WITH_RANDOM_HEX

# Public HTTPS URL (the Cloudflare tunnel) to register the webhook at on start.
TGCTL_CHANNEL_SET_URL=https://claude-channel.example.com/

# Path to the tgctl binary on the VPS.
TGCTL_BIN=/usr/local/bin/tgctl
